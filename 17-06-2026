#include <iostream>
using namespace std;

int main() {
    int arr[5], sum = 0;
    float average;

    // Input array elements
    cout << "Enter 5 elements: ";
    for(int i = 0; i < 5; i++) {
        cin >> arr[i];
        sum += arr[i];
    }

    // Calculate average
    average = (float)sum / 5;

    // Display average
    cout << "Average = " << average;

    return 0;
}
